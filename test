local function ColorRow(parent, name, getC, setC)
    local f = Instance.new("Frame")
    f.Size = UDim2.new(1,0,0,40); f.BackgroundColor3 = T.Card
    f.BorderSizePixel = 0; f.Parent = parent; Corner(f,8)
    local sk = Stroke(f,T.BorderDim,1)
    local l = Lbl(f,name,Enum.Font.GothamSemibold,T.White)
    l.Size = UDim2.new(0.6,0,1,0); l.Position = UDim2.new(0,12,0,0)
    local sw = Instance.new("TextButton")
    sw.Size = UDim2.new(0,52,0,22); sw.Position = UDim2.new(1,-62,0.5,-11)
    sw.BackgroundColor3 = getC(); sw.Text = ""; sw.BorderSizePixel = 0; sw.Parent = f
    Corner(sw,5); Stroke(sw,T.Border,1.5)
    local picker = Instance.new("Frame")
    picker.Size = UDim2.new(1,0,0,0); picker.BackgroundColor3 = T.Card
    picker.BorderSizePixel = 0; picker.ClipsDescendants = true; picker.Parent = parent; Corner(picker,8)
    local open = false
    sw.MouseButton1Click:Connect(function()
        open = not open
        QT(picker,0.22,{Size=open and UDim2.new(1,0,0,95) or UDim2.new(1,0,0,0)},Enum.EasingStyle.Quint)
        if open and #picker:GetChildren()<=1 then
            local ll=Instance.new("UIListLayout"); ll.Padding=UDim.new(0,4); ll.Parent=picker; Pad(picker,8,6)
            local h0,s0,v0=Color3.toHSV(getC())
            local function MS(lt,iv,onChange)
                local sf=Instance.new("Frame"); sf.Size=UDim2.new(1,0,0,21); sf.BackgroundTransparency=1; sf.Parent=picker
                local sl=Lbl(sf,lt,Enum.Font.GothamBold,T.Dim,Enum.TextXAlignment.Center); sl.Size=UDim2.new(0,18,1,0)
                local tr=Instance.new("Frame"); tr.Size=UDim2.new(1,-26,0,5); tr.Position=UDim2.new(0,22,0.5,-2)
                tr.BackgroundColor3=T.BorderDim; tr.BorderSizePixel=0; tr.Parent=sf; Corner(tr,3)
                local fi=Instance.new("Frame"); fi.Size=UDim2.new(iv,0,1,0); fi.BackgroundColor3=T.Accent; fi.BorderSizePixel=0; fi.Parent=tr; Corner(fi,3)
                local kn=Instance.new("TextButton"); kn.Size=UDim2.new(0,12,0,12); kn.Position=UDim2.new(iv,-6,0.5,-6)
                kn.BackgroundColor3=T.White; kn.Text=""; kn.ZIndex=5; kn.Parent=tr; Corner(kn,6)
                local dr=false
                kn.MouseButton1Down:Connect(function() dr=true end)
                UserInputService.InputEnded:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then dr=false end end)
                RunService.RenderStepped:Connect(function()
                    if dr then
                        local p=math.clamp((UserInputService:GetMouseLocation().X-tr.AbsolutePosition.X)/tr.AbsoluteSize.X,0,1)
                        fi.Size=UDim2.new(p,0,1,0); kn.Position=UDim2.new(p,-6,0.5,-6)
                        onChange(p); sw.BackgroundColor3=getC(); SaveSettings()
                    end
                end)
            end
            MS("H",h0,function(p) local _,ss,vv=Color3.toHSV(getC()); setC(Color3.fromHSV(p,ss,vv)) end)
            MS("S",s0,function(p) local hh,_,vv=Color3.toHSV(getC()); setC(Color3.fromHSV(hh,p,vv)) end)
            MS("V",v0,function(p) local hh,ss,_=Color3.toHSV(getC()); setC(Color3.fromHSV(hh,ss,p)) end)
        end
    end)
    f.MouseEnter:Connect(function() QT(sk,0.15,{Color=T.AccentSoft}) end)
    f.MouseLeave:Connect(function() QT(sk,0.15,{Color=T.BorderDim}) end)
end
