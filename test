local function SwitchTab(name)
    for _, n in ipairs(tabNames) do
        tabs[n].Visible = false
        QT(navBtns[n], 0.18, {
            BackgroundColor3       = Color3.fromRGB(0,0,0),
            BackgroundTransparency = 1,
            TextColor3             = T.Dim,
        })
