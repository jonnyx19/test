    f.Size = UDim2.new(1,0,0,54); f.BackgroundColor3 = T.Card
    f.BorderSizePixel = 0; f.Parent = parent; Corner(f,8)
    local sk = Stroke(f,T.BorderDim,1)
    local top = Instance.new("Frame")
    top.Size = UDim2.new(1,-24,0,18); top.Position = UDim2.new(0,12,0,8)
    top.BackgroundTransparency = 1; top.Parent = f
    local nl = Lbl(top,name,Enum.Font.GothamSemibold,T.White)
    nl.Size = UDim2.new(0.65,0,1,0)
    local vl = Lbl(top,string.format("%.2f",def),Enum.Font.GothamBold,T.Accent,Enum.TextXAlignment.Right)
    vl.Size = UDim2.new(0.35,0,1,0); vl.Position = UDim2.new(0.65,0,0,0)
    local track = Instance.new("Frame")
    track.Size = UDim2.new(1,-24,0,5); track.Position = UDim2.new(0,12,0,36)
    track.BackgroundColor3 = T.BorderDim; track.BorderSizePixel = 0; track.Parent = f; Corner(track,3)
    local fill = Instance.new("Frame")
    fill.Size = UDim2.new((def-minv)/(maxv-minv),0,1,0)
    fill.BackgroundColor3 = T.Accent; fill.BorderSizePixel = 0; fill.Parent = track; Corner(fill,3)
    local knob = Instance.new("TextButton")
    knob.Size = UDim2.new(0,15,0,15)
    knob.Position = UDim2.new((def-minv)/(maxv-minv),-7,0.5,-7)
    knob.BackgroundColor3 = T.White; knob.Text = ""; knob.ZIndex = 3; knob.Parent = track; Corner(knob,8)
    local dr = false
    knob.MouseButton1Down:Connect(function() dr = true end)
    UserInputService.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then dr = false end
    end)
    RunService.RenderStepped:Connect(function()
        if dr then
            local p = math.clamp(
                (UserInputService:GetMouseLocation().X - track.AbsolutePosition.X)
                / track.AbsoluteSize.X, 0, 1)
            fill.Size = UDim2.new(p,0,1,0); knob.Position = UDim2.new(p,-7,0.5,-7)
            local val = minv+(maxv-minv)*p
            vl.Text = string.format("%.2f",val); cb(val); SaveSettings()
        end
    end)
    f.MouseEnter:Connect(function() QT(sk,0.15,{Color=T.AccentSoft}) end)
    f.MouseLeave:Connect(function() QT(sk,0.15,{Color=T.BorderDim}) end)
    cb(def)
end
local function Keybind(parent, name, curKey, onSet)
    local f = Instance.new("Frame")
    f.Size = UDim2.new(1,0,0,40); f.BackgroundColor3 = T.Card
    f.BorderSizePixel = 0; f.Parent = parent; Corner(f,8)
    local sk = Stroke(f,T.BorderDim,1)
    local l = Lbl(f,name,Enum.Font.GothamSemibold,T.White)
    l.Size = UDim2.new(0.55,0,1,0); l.Position = UDim2.new(0,12,0,0)
    local kb = Instance.new("TextButton")
    kb.Size = UDim2.new(0,90,0,24); kb.Position = UDim2.new(1,-100,0.5,-12)
    kb.BackgroundColor3 = T.AccentSoft; kb.Text = "["..curKey.Name.."]"
    kb.TextColor3 = T.White; kb.TextScaled = true; kb.Font = Enum.Font.GothamBold
    kb.BorderSizePixel = 0; kb.Parent = f; Corner(kb,6)
    local waiting = false
    kb.MouseButton1Click:Connect(function()
        if waiting then return end
        waiting = true; kb.Text = "..."; QT(kb,0.1,{BackgroundColor3=T.Accent})
        local c; c = UserInputService.InputBegan:Connect(function(inp,gp)
            if gp then return end
            if inp.UserInputType == Enum.UserInputType.Keyboard then
                c:Disconnect(); waiting = false
                kb.Text = "["..inp.KeyCode.Name.."]"
                QT(kb,0.15,{BackgroundColor3=T.AccentSoft})
                onSet(inp.KeyCode); SaveSettings()
            end
        end)
    end)
    f.MouseEnter:Connect(function() QT(sk,0.15,{Color=T.AccentSoft}) end)
    f.MouseLeave:Connect(function() QT(sk,0.15,{Color=T.BorderDim}) end)
end
local function AimbotHotkeyBinder(parent)
    local f = Instance.new("Frame")
    f.Size = UDim2.new(1,0,0,60); f.BackgroundColor3 = T.Card
    f.BorderSizePixel = 0; f.Parent = parent; Corner(f,8)
    local sk = Stroke(f,T.BorderDim,1)
    local topRow = Instance.new("Frame")
    topRow.Size = UDim2.new(1,-24,0,20); topRow.Position = UDim2.new(0,12,0,8)
    topRow.BackgroundTransparency = 1; topRow.Parent = f
    local l = Lbl(topRow,"Aimbot Key",Enum.Font.GothamSemibold,T.White)
    l.Size = UDim2.new(0.5,0,1,0)
    local function GetKeyText()
        if aimbotUseKey and aimbotKey ~= Enum.KeyCode.Unknown then return aimbotKey.Name end
        local m={[Enum.UserInputType.MouseButton1]="LMB",[Enum.UserInputType.MouseButton2]="RMB",[Enum.UserInputType.MouseButton3]="MMB"}
        return m[aimbotMouseBtn] or "RMB"
    end
    local curLbl = Lbl(topRow, GetKeyText(), Enum.Font.GothamBold, T.Accent, Enum.TextXAlignment.Right)
    curLbl.Size = UDim2.new(0.5,0,1,0); curLbl.Position = UDim2.new(0.5,0,0,0)
    local bindBtn = Instance.new("TextButton")
    bindBtn.Size = UDim2.new(1,-24,0,24); bindBtn.Position = UDim2.new(0,12,0,30)
    bindBtn.BackgroundColor3 = T.AccentSoft; bindBtn.Text = "BIND"
    bindBtn.TextColor3 = T.White; bindBtn.TextScaled = true
    bindBtn.Font = Enum.Font.GothamBold; bindBtn.BorderSizePixel = 0
    bindBtn.Parent = f; Corner(bindBtn,6)
    local listening = false
    bindBtn.MouseButton1Click:Connect(function()
        if listening then return end
        listening = true; bindBtn.Text = "HOLD KEY OR MOUSE..."
        QT(bindBtn,0.1,{BackgroundColor3=T.Accent})
        local pressConn, releaseConn
        pressConn = UserInputService.InputBegan:Connect(function(inp, gp)
            if gp then return end
            local isKey   = inp.UserInputType == Enum.UserInputType.Keyboard
            local isMouse = inp.UserInputType == Enum.UserInputType.MouseButton1
                         or inp.UserInputType == Enum.UserInputType.MouseButton2
                         or inp.UserInputType == Enum.UserInputType.MouseButton3
            if not (isKey or isMouse) then return end
            pressConn:Disconnect()
            local capType = inp.UserInputType; local capCode = inp.KeyCode
            bindBtn.Text = "RELEASE TO CONFIRM"
            releaseConn = UserInputService.InputEnded:Connect(function(rel)
                local matchKey   = capType == Enum.UserInputType.Keyboard and rel.KeyCode == capCode
                local matchMouse = capType ~= Enum.UserInputType.Keyboard
                if rel.UserInputType == capType and (matchKey or matchMouse) then
                    releaseConn:Disconnect(); listening = false
                    if capType == Enum.UserInputType.Keyboard then
                        aimbotUseKey = true; aimbotKey = capCode
                    else
                        aimbotUseKey = false; aimbotMouseBtn = capType
                    end
                    curLbl.Text = GetKeyText(); bindBtn.Text = "BIND"
                    QT(bindBtn,0.2,{BackgroundColor3=T.AccentSoft}); SaveSettings()
                end
            end)
        end)
    end)
    f.MouseEnter:Connect(function() QT(sk,0.15,{Color=T.AccentSoft}) end)
    f.MouseLeave:Connect(function() QT(sk,0.15,{Color=T.BorderDim}) end)
end
local function TargetSelector(parent)
