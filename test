                Camera.ViewportSize.Y / 2)
            local hFOV = Camera.FieldOfView * (Camera.ViewportSize.X / Camera.ViewportSize.Y)
            fovCircle.Radius = (aimFOV / hFOV) * (Camera.ViewportSize.X / 2)
        else
            fovCircle.Visible = false
        end
    end

    if aimbotEnabled and IsAimbotActive() then
        local best, bestDist = nil, math.huge
        local bestWorldPos   = nil
        local cx   = Camera.ViewportSize.X / 2
        local cy   = Camera.ViewportSize.Y / 2
        local hFOV2 = Camera.FieldOfView * (Camera.ViewportSize.X / Camera.ViewportSize.Y)
        local fovR  = (aimFOV / hFOV2) * (Camera.ViewportSize.X / 2)
        local camPos  = Camera.CFrame.Position
        local camLook = Camera.CFrame.LookVector
        local myRoot  = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")

        for _, plr in ipairs(Players:GetPlayers()) do
            if plr == LocalPlayer or not plr.Character then continue end
            local char = plr.Character
            local hum  = char:FindFirstChildOfClass("Humanoid")
            -- FIX: skip dead players
            if not hum or hum.Health <= 0 then continue end

            local targetPart, yOffset = GetAimPosition(char)
            if not targetPart then continue end

            local rawPos   = targetPart.Position
            local worldPos = rawPos + yOffset  -- yOffset is now always a Vector3, never nil

            -- Velocity prediction
            if predictionAmount > 0 and lastPositions[plr] then
                local vel = (rawPos - lastPositions[plr]) * 60
                worldPos  = worldPos + vel * predictionAmount * (1/60)
            end
            lastPositions[plr] = rawPos

            if (worldPos - camPos).Unit:Dot(camLook) <= 0 then continue end

            local screenPos, onScreen = Camera:WorldToViewportPoint(worldPos)
            if not onScreen then continue end

            if closestToCrosshair then
                local dx = screenPos.X - cx
                local dy = screenPos.Y - cy
                local d  = math.sqrt(dx*dx + dy*dy)
                if d < fovR and d < bestDist then
                    bestDist = d; best = screenPos; bestWorldPos = worldPos
                    currentTargetPart = targetPart
                end
            else
                if myRoot then
                    local wd = (worldPos - myRoot.Position).Magnitude
                    local sd = math.sqrt((screenPos.X-cx)^2 + (screenPos.Y-cy)^2)
                    if sd < fovR and wd < bestDist then
                        bestDist = wd; best = screenPos; bestWorldPos = worldPos
                        currentTargetPart = targetPart
                    end
                end
            end
        end
        currentTargetPos = best

        if silentAimEnabled and bestWorldPos then
            if UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) then
                pcall(function()
                    local realCF  = Camera.CFrame
                    Camera.CFrame = CFrame.new(camPos, bestWorldPos)
                    mouse1click()
                    Camera.CFrame = realCF   -- restore immediately same frame
                end)
            end
        end

   
        if autoShootEnabled and best and not silentAimEnabled then
            pcall(function() mouse1click() end)
        end

    else
        currentTargetPos  = nil
        currentTargetPart = nil
        lastPositions     = {}
    end

  
    if currentTargetPos and not silentAimEnabled then
        local cur = Vector2.new(Mouse.X, Mouse.Y)
        local mx  = (currentTargetPos.X - cur.X) * smoothness
        local my  = (currentTargetPos.Y - cur.Y) * smoothness
        if aimShakeEnabled and (math.abs(mx) > 0.5 or math.abs(my) > 0.5) then
            mx = mx + math.sin(shakeT * 1.3) * aimShakeAmount
            my = my + math.cos(shakeT * 0.9) * aimShakeAmount
        end
        pcall(function() mousemoverel(mx, my) end)
    end
end)

local function CreateESP(plr)
    if plr == LocalPlayer then return end
    if ESPObjects[plr] then return end

    local Box  = Drawing.new("Square")
    Box.Thickness = espBoxThickness; Box.Filled = false
    Box.Transparency = 1; Box.Color = espBoxColor


    local Fill = Drawing.new("Square")
    Fill.Filled = true; Fill.Thickness = 0
    Fill.Color = espBoxColor; Fill.Transparency = espFillTransp
    Fill.Visible = false

    local Corners = {}
    for i = 1, 8 do
        local ln = Drawing.new("Line")
        ln.Thickness = espBoxThickness + 0.5
        ln.Color = espBoxColor; ln.Transparency = 1; ln.Visible = false
        Corners[i] = ln
    end

    local Name = Drawing.new("Text")
    Name.Size = 14; Name.Center = true; Name.Outline = true
    Name.Color = espNameColor

    local Dist = Drawing.new("Text")
    Dist.Size = 13; Dist.Center = true; Dist.Outline = true
    Dist.Color = T.Dim

    local HBar = Drawing.new("Square")
    HBar.Filled = true; HBar.Thickness = 1; HBar.Color = T.Success

    local HBarBg = Drawing.new("Square")
    HBarBg.Filled = true; HBarBg.Thickness = 0
    HBarBg.Color = Color3.fromRGB(20,20,20); HBarBg.Transparency = 0.5

    local Tr = Drawing.new("Line")
    Tr.Thickness = 1.3; Tr.Color = espTracerColor

    local Skel = {}
    local LN = {
        "HeadToNeck","SpineToLeftShoulder","LeftShoulderToElbow","LeftElbowToWrist",
        "SpineToRightShoulder","RightShoulderToElbow","RightElbowToWrist",
        "SpineToLeftHip","LeftHipToKnee","LeftKneeToAnkle",
        "SpineToRightHip","RightHipToKnee","RightKneeToAnkle"
    }
    for _, n in ipairs(LN) do
        local ln = Drawing.new("Line")
        ln.Thickness = skeletonThickness; ln.Color = skeletonColor; ln.Transparency = 1
        Skel[n] = ln
    end

    ESPObjects[plr] = {
        Box=Box, Fill=Fill, Corners=Corners,
        Name=Name, Dist=Dist, HBar=HBar, HBarBg=HBarBg,
        Tr=Tr, Skel=Skel
    }
end

local function RemoveESP(plr)
    if ESPObjects[plr] then
        local d = ESPObjects[plr]
        pcall(function() d.Box:Remove() end)
        pcall(function() d.Fill:Remove() end)
        for _, ln in pairs(d.Corners) do pcall(function() ln:Remove() end) end
        pcall(function() d.Name:Remove() end)
        pcall(function() d.Dist:Remove() end)
        pcall(function() d.HBar:Remove() end)
        pcall(function() d.HBarBg:Remove() end)
        pcall(function() d.Tr:Remove() end)
        for _, ln in pairs(d.Skel) do pcall(function() ln:Remove() end) end
        ESPObjects[plr] = nil
    end
end

local function HideAll(d)
    d.Box.Visible    = false
    d.Fill.Visible   = false
    for _, ln in pairs(d.Corners) do ln.Visible = false end
    d.Name.Visible   = false
    d.Dist.Visible   = false
    d.HBar.Visible   = false
    d.HBarBg.Visible = false
    d.Tr.Visible     = false
    for _, l in pairs(d.Skel) do l.Visible = false end
end

local function UpdateESP()
    local myRoot = LocalPlayer.Character
        and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    for plr, d in pairs(ESPObjects) do
        local char = plr.Character
        if not char
            or not char:FindFirstChild("Head")
            or not char:FindFirstChild("HumanoidRootPart")
            or not char:FindFirstChild("Humanoid") then
            HideAll(d); continue
        end
        local root = char.HumanoidRootPart
        local head = char.Head
        local hum  = char.Humanoid

        local _, onS = Camera:WorldToViewportPoint(root.Position)
        if not onS then HideAll(d); continue end

        local rp = Camera:WorldToViewportPoint(root.Position)
        local ht = Camera:WorldToViewportPoint(head.Position + Vector3.new(0, 0.7, 0))
        local rb = Camera:WorldToViewportPoint(root.Position - Vector3.new(0, 3, 0))
        local h2 = rb.Y - ht.Y
        local w  = h2 * 0.62

       
        if espEnabled then
            local bx = rp.X - w/2
            local by = ht.Y
            local bw = w
            local bh2 = h2
            d.Box.Color      = espBoxColor
            d.Box.Thickness  = espBoxThickness
            d.Fill.Color     = espBoxColor
            d.Tr.Color       = espTracerColor
            d.Name.Color     = espNameColor
            for _, ln in pairs(d.Corners) do
                ln.Color     = espBoxColor
                ln.Thickness = espBoxThickness + 0.5
            end

           
            if espChams or espBoxFilled then
                d.Fill.Visible      = true
                d.Fill.Size         = Vector2.new(bw, bh2)
                d.Fill.Position     = Vector2.new(bx, by)
                d.Fill.Transparency = espFillTransp
            else
                d.Fill.Visible = false
            end

            
            if espBoxStyle == "CORNER" then
                d.Box.Visible = false
 
                local cx2 = bw * 0.22
                local cy2 = bh2 * 0.18
   
                d.Corners[1].From=Vector2.new(bx,by);          d.Corners[1].To=Vector2.new(bx+cx2,by)
                d.Corners[2].From=Vector2.new(bx,by);          d.Corners[2].To=Vector2.new(bx,by+cy2)
      
                d.Corners[3].From=Vector2.new(bx+bw,by);       d.Corners[3].To=Vector2.new(bx+bw-cx2,by)
                d.Corners[4].From=Vector2.new(bx+bw,by);       d.Corners[4].To=Vector2.new(bx+bw,by+cy2)
                d.Corners[5].From=Vector2.new(bx,by+bh2);      d.Corners[5].To=Vector2.new(bx+cx2,by+bh2)
                d.Corners[6].From=Vector2.new(bx,by+bh2);      d.Corners[6].To=Vector2.new(bx,by+bh2-cy2)
           
                d.Corners[7].From=Vector2.new(bx+bw,by+bh2);   d.Corners[7].To=Vector2.new(bx+bw-cx2,by+bh2)
                d.Corners[8].From=Vector2.new(bx+bw,by+bh2);   d.Corners[8].To=Vector2.new(bx+bw,by+bh2-cy2)
                for _, ln in pairs(d.Corners) do ln.Visible = true end
            else
           
                for _, ln in pairs(d.Corners) do ln.Visible = false end
                d.Box.Visible   = true
                d.Box.Size      = Vector2.new(bw, bh2)
                d.Box.Position  = Vector2.new(bx, by)
            end

          
            d.Name.Visible = espNames
            if espNames then
                d.Name.Text     = plr.Name
                d.Name.Position = Vector2.new(rp.X, by - 16)
            end

       
            if espDistance and myRoot then
                local dist = math.floor((root.Position - myRoot.Position).Magnitude)
                d.Dist.Visible  = true
                d.Dist.Text     = dist .. "m"
                d.Dist.Position = Vector2.new(rp.X, by + bh2 + 2)
            else
                d.Dist.Visible = false
            end

         
            if espHealth then
                local hp = math.clamp(hum.Health / math.max(hum.MaxHealth, 1), 0, 1)
                local barH = bh2 * hp
                local barX = bx - 7
                d.HBarBg.Visible  = true
                d.HBarBg.Size     = Vector2.new(4, bh2)
                d.HBarBg.Position = Vector2.new(barX, by)
                d.HBar.Visible    = true
                d.HBar.Color      = Color3.fromHSV(hp * 0.33, 1, 1)
                d.HBar.Size       = Vector2.new(4, barH)
                d.HBar.Position   = Vector2.new(barX, by + bh2 - barH)
            else
                d.HBar.Visible   = false
                d.HBarBg.Visible = false
            end

         
            if tracersEnabled then
                d.Tr.Visible = true
                local fromY = espTracerOrigin == "TOP"    and 0
                           or espTracerOrigin == "CENTER" and Camera.ViewportSize.Y / 2
                           or Camera.ViewportSize.Y   -- BOTTOM default
                d.Tr.From = Vector2.new(Camera.ViewportSize.X / 2, fromY)
                d.Tr.To   = Vector2.new(rp.X, by + bh2)
            else
                d.Tr.Visible = false
            end
        else
            d.Box.Visible    = false
            d.Fill.Visible   = false
            for _, ln in pairs(d.Corners) do ln.Visible = false end
            d.Name.Visible   = false
            d.Dist.Visible   = false
            d.HBar.Visible   = false
            d.HBarBg.Visible = false
            d.Tr.Visible     = false
        end

   
        if skeletonEnabled then
            for _, ln in pairs(d.Skel) do
                ln.Thickness = skeletonThickness
                ln.Color     = skeletonColor
            end
            local function wp(p)
                if not p then return nil end
                local sp, vis = Camera:WorldToViewportPoint(p.Position)
                return vis and Vector2.new(sp.X, sp.Y) or nil
            end
            local H   = char:FindFirstChild("Head")
            local HRP = char:FindFirstChild("HumanoidRootPart")
            local LA  = char:FindFirstChild("LeftUpperArm")  or char:FindFirstChild("Left Arm")
            local LF  = char:FindFirstChild("LeftLowerArm")
            local LH  = char:FindFirstChild("LeftHand")
            local RA  = char:FindFirstChild("RightUpperArm") or char:FindFirstChild("Right Arm")
            local RF  = char:FindFirstChild("RightLowerArm")
            local RH  = char:FindFirstChild("RightHand")
            local LL  = char:FindFirstChild("LeftUpperLeg")  or char:FindFirstChild("Left Leg")
            local LS  = char:FindFirstChild("LeftLowerLeg")
            local LFt = char:FindFirstChild("LeftFoot")
            local RL  = char:FindFirstChild("RightUpperLeg") or char:FindFirstChild("Right Leg")
            local RS  = char:FindFirstChild("RightLowerLeg")
            local RFt = char:FindFirstChild("RightFoot")
            local function dL(n, p1, p2)
                local ln = d.Skel[n]
                if p1 and p2 then
                    ln.Visible = true; ln.From = p1; ln.To = p2
                else
                    ln.Visible = false
                end
            end
            dL("HeadToNeck",            wp(H),   wp(HRP))
            dL("SpineToLeftShoulder",   wp(HRP), wp(LA))
            dL("LeftShoulderToElbow",   wp(LA),  wp(LF))
            dL("LeftElbowToWrist",      wp(LF),  wp(LH))
            dL("SpineToRightShoulder",  wp(HRP), wp(RA))
            dL("RightShoulderToElbow",  wp(RA),  wp(RF))
            dL("RightElbowToWrist",     wp(RF),  wp(RH))
            dL("SpineToLeftHip",        wp(HRP), wp(LL))
            dL("LeftHipToKnee",         wp(LL),  wp(LS))
            dL("LeftKneeToAnkle",       wp(LS),  wp(LFt))
            dL("SpineToRightHip",       wp(HRP), wp(RL))
            dL("RightHipToKnee",        wp(RL),  wp(RS))
            dL("RightKneeToAnkle",      wp(RS),  wp(RFt))
        else
            for _, ln in pairs(d.Skel) do ln.Visible = false end
        end
    end
end


