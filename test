        seg.Text = opt.label; seg.TextScaled = true; seg.Font = Enum.Font.GothamBold
        seg.TextColor3 = (opt.part==aimPartName) and T.White or T.Dim
        seg.BorderSizePixel = 0; seg.ZIndex = 3; seg.AutoButtonColor = false
        seg.Parent = row; Corner(seg,5); segs[opt.part] = seg
        seg.MouseButton1Click:Connect(function()
            for _, b in pairs(segs) do QT(b,0.15,{BackgroundTransparency=1,TextColor3=T.Dim}) end
            QT(seg,0.15,{BackgroundTransparency=0,TextColor3=T.White})
            aimPartName = opt.part; SaveSettings()
